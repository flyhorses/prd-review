# =============================================
# PRD Review Platform - 环境变量配置
# =============================================

# === AI API 配置 (必填) ===
AI_BAILIAN_API_KEY=your_api_key_here

# === AI 模型配置 (可选) ===
# AI_MODEL=qwen-plus
# APP_AI_STRUCTURED_MAX_ATTEMPTS=2
# APP_AI_STRUCTURED_INCLUDE_LAST_ERROR=true

# === 数据库配置 (可选) ===
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=password
# POSTGRES_DB=prd

# === MinIO 对象存储配置 (可选) ===
# MINIO_ROOT_USER=minioadmin
# MINIO_ROOT_PASSWORD=minioadmin
# APP_STORAGE_BUCKET=prd
# APP_STORAGE_REGION=us-east-1

# === PRD 评审配置 (可选) ===
# APP_PRD_MAX_CONTENT_LENGTH=100000
# APP_PRD_DEFAULT_DETAIL_LEVEL=BASIC
